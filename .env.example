# ──────────────────────────────────────────────────────────────────────────────
# tagix (Highermind v2) — variáveis de ambiente. Copie para `.env` e preencha.
# NUNCA commite o `.env` real. Placeholders aqui são intencionalmente inválidos.
# ──────────────────────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
LOG_LEVEL=debug

# --- Postgres (pgvector) ---
DATABASE_URL=postgres://hm:hm@localhost:5432/highermind

# --- Redis (cache + locks + socket adapter) ---
REDIS_URL=redis://localhost:6379

# --- RabbitMQ (filas) ---
AMQP_URL=amqp://hm:hm@localhost:5672

# --- Storage (dev: local; prod: Cloudflare R2 / S3-compatível) ---
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./tmp/storage
R2_ACCOUNT_ID=your-account-id-here
R2_ACCESS_KEY_ID=your-access-key-here
R2_SECRET_ACCESS_KEY=your-secret-here
R2_BUCKET=highermind-media

# --- Auth (Supabase atrás de IAuthProvider) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=change-me-service-key

# --- Criptografia at-rest (AES-256-GCM) — gere 32 bytes hex ---
ENCRYPTION_KEY=change-me-32-byte-hex-key
ENCRYPTION_KEY_VERSION=1

# --- LLM router (OpenRouter — chat completion) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- OpenAI direto (embeddings / whisper / vision) ---
OPENAI_API_KEY=sk-proj-your-key-here
EMBEDDING_MODEL=text-embedding-3-small

# --- Agent runtime (token interno compartilhado API <-> Python) ---
AGENT_RUNTIME_URL=http://localhost:8001
AGENT_RUNTIME_TOKEN=change-me-random-token

# --- Meta (WhatsApp + Instagram, Tech Provider) — vazio em dev ---
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# --- Ports ---
API_PORT=3001
WEB_PORT=3000
AGENT_RUNTIME_PORT=8001

# --- CORS (nunca `*` como default) — aceita CSV (várias origens) (F10-S07) ---
CORS_ORIGIN=http://localhost:3000
# Origens extra para connect-src da CSP (CSV) — ex. telemetria/Sentry browser.
CSP_CONNECT_SRC=

# --- Feature flags ---
BILLING_ENABLED=false

# --- Observabilidade (F10-S01) — tudo opt-in; sem valor = no-op ---
# Traces + métricas OTLP: setar liga o exporter (convenção OTel).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_METRICS_EXPORT_INTERVAL_MS=60000
# Sentry por runtime (no-op sem DSN).
SENTRY_DSN_API=
SENTRY_DSN_WORKERS=
SENTRY_DSN_AGENT_RUNTIME=
SENTRY_TRACES_SAMPLE_RATE=0
HM_RELEASE=
# Servidor /metrics dos workers (liga quando a porta está setada).
WORKERS_METRICS_PORT=9101
WORKERS_METRICS_HOST=0.0.0.0
# Grafana (profile observability do docker-compose).
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# --- Variáveis NEXT_PUBLIC_ (embutidas no bundle JS — NUNCA coloque segredos aqui) ---
# URL da API vista pelo browser. Em dev: vazio (Next proxia /api → localhost:3001).
# Em produção: https://api.seudominio.com — configure na Vercel, não no .env.
NEXT_PUBLIC_API_URL=

# Meta Embedded Signup (botão "Conectar com a Meta" em Settings → Canais). App ID e
# Config ID são PÚBLICOS (embutidos no client). Em PROD o build mapeia META_APP_ID/
# META_CONFIG_ID → estes (docker-compose.prod.yml). Em DEV, defina em apps/web/.env.local.
NEXT_PUBLIC_META_APP_ID=
NEXT_PUBLIC_META_CONFIG_ID=

# --- Sentry browser do web (F10-S13) — opt-in; sem DSN = no-op ---
# DSN do Sentry é por design público (rate-limited por DSN, não é segredo).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN_WEB=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0
NEXT_PUBLIC_HM_ENV=
NEXT_PUBLIC_HM_RELEASE=
NEXT_PUBLIC_SENTRY_TUNNEL_ROUTE=
# Upload de source maps no build (CI/Linux) — opt-in; build não falha sem eles.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
