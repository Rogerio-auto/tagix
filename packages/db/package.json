{
  "name": "@hm/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./seed/pipeline_templates": "./src/seed/pipeline_templates.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
