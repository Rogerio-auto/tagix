{
  "name": "tagix",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Highermind v2 — plataforma multi-tenant de atendimento, vendas conversacionais e automação.",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @hm/api --filter @hm/web dev",
    "dev:all": "pnpm --parallel --filter @hm/api --filter @hm/web --filter @hm/workers dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "pnpm -r --if-present build",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
