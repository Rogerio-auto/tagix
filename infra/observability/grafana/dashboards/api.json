{
  "uid": "hm-api",
  "title": "tagix — API (RED)",
  "tags": ["tagix", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s) por status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "hm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_requests_total{service=\"hm-api\"}[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx %)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "hm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{service=\"hm-api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{service=\"hm-api\"}[5m])), 1)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency p50 / p95 / p99 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "hm-prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"hm-api\"}[5m])))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"hm-api\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{service=\"hm-api\"}[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "title": "Top rotas por latência p95 (s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "hm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket{service=\"hm-api\"}[5m]))))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Mensagens publicadas na fila (msg/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "hm-prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (topic, result) (rate(hm_mq_published_total[5m]))",
          "legendFormat": "{{topic}} {{result}}"
        }
      ]
    }
  ]
}
