{
  "specialists": {
    "default": "backend-engineer",
    "patterns": [
      { "pattern": "^apps/web/", "specialist": "frontend-engineer" },
      { "pattern": "^apps/api/", "specialist": "backend-engineer" },
      { "pattern": "^apps/workers/", "specialist": "backend-engineer" },
      { "pattern": "^apps/agent-runtime/", "specialist": "python-engineer" },
      { "pattern": "^packages/ui/", "specialist": "frontend-engineer" },
      { "pattern": "^packages/design-tokens/", "specialist": "frontend-engineer" },
      { "pattern": "^packages/", "specialist": "backend-engineer" },
