# =============================================================================
# Leadium — variáveis de PRODUÇÃO (VPS Swarm).
# Copie para /opt/leadium/.env NO SERVIDOR e preencha. NUNCA comite o .env real.
# Gere segredos fortes com:  openssl rand -base64 36 | tr -dc 'A-Za-z0-9' | head -c 48
# =============================================================================

# --- Infra própria da Leadium (isolada; hostnames = nomes de serviço do stack) ---
PG_USER=leadium
PG_PASSWORD=__GERAR__            # senha forte
PG_DB=leadium
RABBITMQ_USER=leadium
RABBITMQ_PASSWORD=__GERAR__      # senha forte

# DATABASE_URL/REDIS_URL/AMQP_URL são montadas no compose a partir dos valores acima.

# --- App ---
LOG_LEVEL=info
HM_RELEASE=                      # opcional: tag/commit do release (observabilidade)

# --- Auth (Supabase — projeto de PRODUÇÃO novo) ---
AUTH_PROVIDER=supabase
SUPABASE_URL=https://__PROJ__.supabase.co
SUPABASE_ANON_KEY=__DO_PAINEL_SUPABASE__
SUPABASE_SERVICE_KEY=__DO_PAINEL_SUPABASE__   # service_role — segredo de servidor

# --- Cadastro self-serve (F44) ---
# Destino dos links de verificação/reset (allowlistar no Supabase Auth → URL Config).
AUTH_EMAIL_REDIRECT_URL=https://app.leadium.com.br
# Cloudflare Turnstile (captcha do signup). SECRET = server-side (verify); SITE_KEY =
# pública (build-time do web → NEXT_PUBLIC). Sem o SECRET, prod bloqueia todo signup
# (fail-closed). Sem email/SMTP configurado no Supabase, verify/reset não chegam.
TURNSTILE_SECRET_KEY=__DO_PAINEL_CLOUDFLARE__
NEXT_PUBLIC_TURNSTILE_SITE_KEY=__DO_PAINEL_CLOUDFLARE__

# --- Criptografia de credenciais de canal (at-rest) ---
ENCRYPTION_KEY=__GERAR__         # 64 chars HEX (32 bytes): openssl rand -hex 32
ENCRYPTION_KEY_VERSION=1

# --- IA ---
OPENROUTER_API_KEY=__DO_OPENROUTER__
OPENAI_API_KEY=                  # opcional (embeddings diretos); senão usa OpenRouter
EMBEDDING_MODEL=text-embedding-3-small
AGENT_RUNTIME_TOKEN=__GERAR__    # token compartilhado api <-> agent-runtime

# --- Canais Meta (WhatsApp/Instagram) — preencher quando o WABA real existir ---
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# --- Storage de mídia ---
# 'local' = volume leadium_storage (default). Para Cloudflare R2, troque e preencha R2_*.
STORAGE_DRIVER=local
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# --- Rede / segurança ---
CORS_ORIGIN=https://app.leadium.com.br,https://leadium.com.br
CSP_CONNECT_SRC=
BILLING_ENABLED=false

# ── Pagamentos: AbacatePay (F41) ──────────────────────────────────────────────
# Gateway único da plataforma (Leadium é o merchant). NUNCA commitar valores reais.
# Key de dev vs produção: rotacionar ao ir pra prod (ver docs/runbooks/payments-abacatepay.md).
ABACATEPAY_API_KEY=
# Secret do webhook: a AbacatePay o anexa na QUERY STRING do endpoint registrado
# (?webhookSecret=...). Auth PRIMÁRIA do webhook — sem/errado => 401 (fail-closed).
ABACATEPAY_WEBHOOK_SECRET=
# Chave PÚBLICA da AbacatePay (camada extra opcional): se setada, exige o header
# x-webhook-signature = HMAC-SHA256(base64) do corpo bruto com esta chave.
ABACATEPAY_PUBLIC_KEY=
# Régua de cobrança PIX (dias). Defaults no worker: lead=3, grace=3, pastdue=7.
BILLING_DUNNING_LEAD_DAYS=
BILLING_DUNNING_GRACE_DAYS=
BILLING_DUNNING_PASTDUE_DAYS=
# Validade do QR PIX por ciclo (segundos).
BILLING_PIX_EXPIRES_SECONDS=
